# ── Todoist ──────────────────────────────────────────────────────────────────
TODOIST_TOKEN=your_todoist_api_token_here

# ── Google Calendar ───────────────────────────────────────────────────────────
# Make each calendar "public" in Google Calendar settings, then paste IDs here
GOOGLE_CALENDAR_ID_RABIA=rabia@gmail.com
GOOGLE_CALENDAR_ID_CLARE=clare@gmail.com
# Create a project at console.cloud.google.com, enable Calendar API, create API key
GOOGLE_API_KEY=your_google_api_key_here

# ── Location (for weather + sun) ──────────────────────────────────────────────
LAT=40.7128
LON=-74.0060
CITY=New York

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
